  "author": "Summoned Tech <dev@summoned.tech>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/summoned-tech/summoned-sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/summoned-tech/summoned-sdk-ts/issues"
  },
  "homepage": "https://github.com/summoned-tech/summoned-ai-gateway",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
